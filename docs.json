{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Aloro",
  "description": "Step-by-step guides for every product—platform setup, analytics, and integrations in one place.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Changelog",
          "icon": "scroll-text",
          "href": "https://www.mintlify.com/docs/changelog"
        },
        {
          "anchor": "Help",
          "icon": "life-buoy",
          "href": "https://www.mintlify.com/docs/contact-support"
        }
      ]
    },
    "groups": [
      {
        "group": "Start",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "aloro/bun-venit",
          "aloro/quickstart",
          "aloro/concepte"
        ]
      },
      {
        "group": "Platformă",
        "icon": "layout-dashboard",
        "expanded": true,
        "pages": [
          "aloro/dashboard",
          "aloro/clienti",
          "aloro/apeluri",
          "aloro/campanii"
        ]
      },
      {
        "group": "Agenți AI",
        "icon": "bot",
        "expanded": true,
        "pages": [
          "aloro/agenti",
          "aloro/prompturi",
          "aloro/snippets",
          "aloro/tools",
          "aloro/extragere-date",
          "aloro/catalog-produse"
        ]
      },
      {
        "group": "Telefonie",
        "icon": "phone",
        "expanded": true,
        "pages": [
          "aloro/numere-telefon",
          "aloro/inbound-outbound",
          "aloro/telnyx",
          "aloro/livekit-trunks"
        ]
      },
      {
        "group": "Integrări",
        "icon": "plug",
        "expanded": true,
        "pages": [
          "aloro/api-webhooks",
          "aloro/api-keys",
          "aloro/webhook-logs"
        ]
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  }
}
